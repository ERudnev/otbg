---
# scorewarrior cpp-battle-test baseline, stripped to essentials.
# Only three project overrides; everything else is clang-format defaults or scorewarrior core.
# https://clang.llvm.org/docs/ClangFormatStyleOptions.html
#
# Project overrides (only):
#   UseTab: Never
#   AfterStruct / AfterUnion: false
#   CompactNamespaces: false

Language: Cpp
Standard: c++20
ColumnLimit: 120
UseTab: Never
IndentWidth: 4
ContinuationIndentWidth: 8
InsertNewlineAtEOF: true
RemoveSemicolon: true

InsertBraces: true
Cpp11BracedListStyle: true
BreakBeforeBraces: Custom
BraceWrapping:
  AfterClass: true
  AfterControlStatement: Always
  AfterFunction: true
  AfterNamespace: true
  AfterStruct: false
  AfterUnion: false
  BeforeCatch: true
  BeforeElse: true
  BeforeLambdaBody: true
  BeforeWhile: true

AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
CompactNamespaces: false

AlwaysBreakTemplateDeclarations: Yes
BreakBeforeBinaryOperators: All
BreakBeforeTernaryOperators: true
PointerAlignment: Left
ReferenceAlignment: Left
QualifierAlignment: Left

AccessModifierOffset: -4
EmptyLineBeforeAccessModifier: Always
PackConstructorInitializers: Never
BinPackArguments: false
BinPackParameters: false
AlignAfterOpenBracket: AlwaysBreak

NamespaceIndentation: All
FixNamespaceComments: false
SpaceBeforeParens: ControlStatements

SortIncludes: false
